# Copy to `.env` and adjust for your deployment.

# host:port the auth server advertises in the realm list — i.e. where the
# client connects for the world server after auth. Must be reachable from
# every client. Leave commented out for single-machine dev (defaults to
# localhost:8085).
# WOW_REALM_ADDRESS=YOUR.SERVER.IP:8085

# Note: this server unconditionally auto-creates an account on first login
# (password = username). There is no toggle — the behavior is always on.
# Don't expose this server to the public internet.

# Enable the Tracy profiler. `1` attaches a `tracing-tracy` layer to the
# tracing subscriber so a Tracy GUI can collect zones, plots, and frame
# data. Unset or `0` means zero profiler overhead — leave off for normal
# runs and only flip on when actively profiling.
# WOW_TRACY=1
